<aside class="nv16-country-selector" style="height: 0px;">
  <div class="nv16-country-selector__content-wrap">
    <div class="nv16-country-selector__content">
      <label class="nv16-country-selector__description" for="countrySelect">Choose your location and language.</label>
      <div class="nv16-country-selector__select-contaniner">
        <div class="nv16-country-selector__menu">
          <div class="menu" data-comp-name="menu">
            <select id="countrySelect" class="menu__select" tabindex="-1">
              
                <option selected value="us" data-country-type="sitecd" an-tr="nv16_country selector-error page-drop down menu-navigation2" an-ca="navigation" an-ac="gnb" an-la="country selector">USA / ENGLISH</option>
              
              <option value="other" lang="en" an-tr="nv16_country selector-error page-drop down menu-navigation2" an-ca="navigation" an-ac="gnb" an-la="country selector">Other Countries</option>
            </select>
            <button class="menu__select-field" aria-haspopup="listbox" aria-expanded="false" type="button" data-aria-label="Choose your location and language.">
              <span class="menu__select-field-text"></span>
              <svg class="menu__select-field-icon down" focusable="false" aria-hidden="true">
                <use xlink:href="#open-down-bold" href="#open-down-bold"></use>
              </svg>
              <svg class="menu__select-field-icon up" focusable="false" aria-hidden="true">
                <use xlink:href="#close-up-bold" href="#close-up-bold"></use>
              </svg>
            </button>
          </div>
        </div>
        <div class="nv16-country-selector__continue">
          <button class="cta cta--contained cta--black" data-action="countrySelectorContinue" an-tr="nv16_country selector-error page-cta-navigation2" an-ca="navigation" an-ac="gnb" an-la="country selector:continue">Continue</button>
        </div>
      </div>
      <button class="nv16-country-selector__close" data-action="countrySelectorClose" an-tr="nv16_country selector-error page-cta-navigation2" an-ca="navigation" an-ac="gnb" an-la="country selector:close">
        <span class="hidden">Close</span>
        <svg class="icon" focusable="false" aria-hidden="true">
          <use xlink:href="#delete-bold" href="#delete-bold"></use>
        </svg>
      </button>
    </div>
  </div>
</aside>


	
		
	
	
	
		
