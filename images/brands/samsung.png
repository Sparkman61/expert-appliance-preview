    <script type="text/javascript">
        digitalData.page.pathIndicator.depth_2 = "".replace(/&/g, ' and ').replace(/  /g,' ');
        digitalData.page.pathIndicator.depth_3 = "".replace(/&/g, ' and ').replace(/  /g,' ');
        digitalData.page.pathIndicator.depth_4 = "".replace(/&/g, ' and ').replace(/  /g,' ');
        digitalData.page.pathIndicator.depth_5 = "".replace(/&/g, ' and ').replace(/  /g,' ');

        // UAME-2612
        document.addEventListener("DOMContentLoaded", () => {
            const smartTvPages = ["/us/tvs/smart-tv/samsung-tv-apps/", "/us/tvs/smart-tv/samsung-tv-apps-detail/", "/us/tvs/smart-tv/highlights/", "/us/tvs/smart-tv/samsung-vision-ai/",
            "/us/tvs/smart-tv/smart-hub-and-apps/", "/us/tvs/smart-tv/samsung-tv-plus/","/us/tvs/smart-tv/smart-home/","/us/tvs/smart-tv/connect-your-phone/", "/us/tvs/smart-tv/one-remote/"];
        
            if(window.location.pathname === "/us/apps/") {
                digitalData.page.siteSection = "apps";
                digitalData.page.site_section = "apps";
                digitalData.page.allPageTrack = "apps home";
                digitalData.page.page_track = "apps home";
                window.site_section = "apps";
                window.page_track = "apps home";
            } else if(window.location.pathname.includes("/us/apps/") || window.location.pathname.includes("/us/appstore/app/") || smartTvPages.some(page => window.location.pathname === page)) {
                digitalData.page.siteSection = "apps";
                digitalData.page.site_section = "apps";
                digitalData.page.allPageTrack = "apps detail";
                digitalData.page.page_track = "apps detail";
                window.site_section = "apps";
                window.page_track = "apps detail";
            }
        });

    </script>   


