ight:700;text-transform:capitalize;}.css-1hpx0g7 :has(sup){-webkit-text-decoration:none;text-decoration:none;}</style><style data-emotion="css 1waoccr">.css-1waoccr{margin:0;font-weight:400;font-size:0.75rem;text-transform:inherit;line-height:1.22;font-family:"LGEI Text",sans-serif;overflow-wrap:inherit;margin-top:-0.25rem;font-weight:700;text-transform:capitalize;}.css-1waoccr :has(sup){-webkit-text-decoration:none;text-decoration:none;}</style><span class="MuiTypography-root MuiTypography-caption css-1waoccr">Top</span></button></section><script>
    const baseUrl = '/us';
    const COMMON_SCRIPT_ID = 'lg-common-scripts';
    const COMMON_SCRIPT_TIMEOUT = 1000 * 10;
    const handleAppendScript = (baseUrl) => {
      const createdScriptTag = document.createElement('script');

      if (createdScriptTag) {
        createdScriptTag.id = COMMON_SCRIPT_ID;
        createdScriptTag.src = baseUrl + '/static-resources/common-scripts.js';
        createdScriptTag.defer = true;
      }

      document.body.appendChild(createdScriptTag);
    };

    const postContentScriptConfig = {
      storePath: baseUrl,
    };
    window.postContentScriptConfig = postContentScriptConfig;

    if (window.requestIdleCallback) {
      requestIdleCallback(() => handleAppendScript(baseUrl), {
        timeout: COMMON_SCRIPT_TIMEOUT,
      });
    } else {
      // In case of Safari requestIdleCallback is not available so used timeout
      setTimeout(() => {
        handleAppendScript(baseUrl);
      }, COMMON_SCRIPT_TIMEOUT);
    }
  </script></div><script id="__NEXT_DATA__" type="application/json" crossorigin="">{"props":{"pageProps":{"commonSsrProps":{"labelData":{"global":{"label":{"common":{"cart":{"add":"Add to Cart","notify":"Notify Me","retailer":"Find a Retailer","modalAdd":"Added to your cart","modalFail":"Add to your cart failed","modalFailMsg":"The item cannot be ordered at this time.","modalOutOfStock":"This item is temporarily out of stock.","additionalServices":"Additional Services","continue":"Continue Shopping","viewCart":"View Cart \u0026 Checkout","recommended":"Recommended accessories/products"},"notify":{"heading":"We’ll let you know when it’s back in stock","subHeading":"Enter your information below to receive a notification when the product is available.","zipPlaceholder":"ZIP Code","emailPlaceholder":"Email","invalidZip":"Enter valid ZIP Code","invalidEmail":"Please enter a valid email","optMsg":"Sign me up to receive product tips and tricks, special offers and more from LG. By signing up for these emails, you are agreeing to the","policy":"LG privacy policy","cancel":"Cancel","notifyMe":"Notify Me"},"search":{"heading":"What can we help you find today?","placeholder":"Search LG","popular":"Popular searches","help":"Can we help?","prodSupport":"Product support","chat":"Online chat","chatIcon":"https://media.us.lg.com/asset/273962d3-a581-4070-8c91-f06de30bd00c/icon_ShoppingBag.svg","chatTitle":"Talk to an Expert","chatLink":"javascript:(function(){if(window.sprChat){window.sprChat('open');document.querySelectorAll('.MuiModal-root .MuiBackdrop-root')[0].click();}else{alert('Chatbot not initialized on this page.');}})();","chatContent":"We'll help you find the right item and best offers","chatBtn":"Start a Chat","emailSupport":"Email support","history":"Search history","clearHistory":"Clear","needSupport":"Need product support?","moreSuggestion":"More search suggestions","ourProducts":"Our products"},"compare":{"dialogHeading":"Compare Products","remove":"Remove","highlight":"Show differences only","add":"Add to Compare","compare":"Compare","clear":"Clear","stickyHeading":"Add up to 4 items","aiQuickPickTitle":"Quick Pick","aiSimilaritiesTitle":"Features on every model","aiEnable":"true","ai":{"legalDisclaimer":"This summary is generated with an AI tool using LG product information. It is provided for your convenience and does not replace the full product descriptions, specifications, or warranties. Please see the full product description and “Specifications” section on this page for complete and current details."}},"stock":{"in":"In stock","out":"Out of stock"},"copyright":"Copyright © 2009-\u003cto\u003e LG Electronics. All Rights Reserved.","subscription":{"promoTagLabel":"Subscribe \u0026 save","percentageTitleText":"Subscribe and save up to ${TOTAL_RATE} *","fixedTitleText":"Subscribe and save ${TOTAL_RATE} *","percentageDescriptionText":"Subscribe for an LG Refrigerator automatic filter replacement service and receive ${TOTAL_RATE} off MSRP for your first filter and ${DISCOUNT_RATE} on all subsequent renewal filters.","fixedDescriptionText":"Subscribe for a LG Refrigerator automatic filter replacement service and receive ${TOTAL_RATE} off MSRP on every filter, with every auto-replacement.","period6Month":"Delivery every 6 Months","period3Month":"Delivery every 3 Months","periodSinglePurchase":"Single purchase","subscriptionOptions":"Subscription options","proceed":"Add to cart","singlePurchaseTitle":"Single purchase","singlePurchaseDescription":"","month3Title":"3 months","month3Description":"","month4Title":"4 months","month4Description":"Recommended for 4-6 member households","month5Title":"5 months","month5Description":"Recommended for 3-4 member households","month6Title":"6 months","month6Description":"Most popular","month2Title":"2 months","deliveryDescription":"1 filter delivered every {VALUE_PLACE_HOLDER}"},"additionalService":{"installation":{"title":"Installation services","subTitle":"Professional installation and setup services are available for this product."},"wallmount":{"title":"Add TV Setup","icon":"HomeRepairServiceOutlined","subTitle":"","description":"Includes installation of TV mounting bracket, mounting of TV, load testing of the hardware.","buttonLabel":"What's included?","imageUrl":"https://media.us.lg.com/transform/9210c2ec-9063-41f1-8504-ce982c26d627/Angi_Logo","linkText":"Learn more","linkUrl":"https://www.angi.com/landing/how-it-works","overlayTitle":"Wall mounting by Angi","itemTitle":"Wall Mounting by Angi"},"esp":{"title":"Add LG Premium Care by Asurion","icon":"GppGoodOutlined","subTitle":"Stay protected after manufacturer standard parts and labor warranty ends. No deductible or additional fees.","description":"","itemTitle":"-Year Additional Protection","footerText":"Limitations and exclusions apply.","linkText":"Asurion's terms \u0026 conditions","buttonLabel":"Learn more","learnMore":{"title":"LG Premium Care by Asurion","buttonText":"Close","size":"md","body":"\u003ch6\u003e  Premium Care Promise  \u003c/h6\u003e  \u003cp\u003e  With LG Premium Care by Asurion you can rest easy knowing that you are covered. If your product can't be repaired, it'll be replaced or you'll be reimbursed for the price of the product-that's a promise.  \u003c/p\u003e  \u003ch6\u003e  Real-time Updates  \u003c/h6\u003e  \u003cp\u003e  If you need to file a service claim, you can opt-in to receive real-time updates regarding the status of your service repair.  \u003c/p\u003e  \u003ch6\u003e  Service On Your Schedule  \u003c/h6\u003e  \u003cp\u003e  With LG Premium Care by Asurion, if you ever need service, it's easy to set up a service appointment that fits your schedule. You can schedule your appointment online at \u003ca style=\"color:#000;\" href=\"https://www.asurion.com/lg\" target=\"_blank\"\u003ewww.Asurion.com/LG\u003c/a\u003e or call customer service at 855-549-0540 Monday - Friday 8am - 11pm EST, Saturday - Sunday 9am - 6pm EST to speak to an agent and start your service claim.  \u003c/p\u003e  \u003ch6\u003e  Triage \u0026 Troubleshooting  \u003c/h6\u003e  \u003cp\u003e  Pre-service diagnostics and parts come straight from the technical experts to keep your down time short and your repair service efficient. Sometimes problems are solved over the phone without needing an in-home appointment.  \u003c/p\u003e  \u003ch6\u003e  24/7 Claim Filing  \u003c/h6\u003e  \u003cp\u003e  Every LG Premium Care by Asurion Plan includes 24/7 access to an online service portal, where you can file your claim day or night, 7 days a week 365 days a year.  \u003c/p\u003e  \u003ch6\u003e  Coverage of 'in-the-box' Accessories  \u003c/h6\u003e  \u003cp\u003e  With LG Premium Care by Asurion, you're covered with the repair or replacement of accessories included 'in the box' by the manufacturer (including TV remote control).  \u003c/p\u003e  \u003ch6\u003e  Food Loss Coverage (For Refrigerator or Freezer)   \u003c/h6\u003e  \u003cp\u003e  When you purchase an LG Premium Care by Asurion Plan for your refrigerator or freezer, you also get up to $300 food loss reimbursement resulting from a breakdown of a covered refrigerator or freezer.  \u003c/p\u003e  \u003cspan\u003e  Limitations and Exclusions apply. \u003ca href=\"https://www.lgpremiumcare.com/whatsCovered\" target=\"_blank\"\u003eAsurion's Terms \u0026 Conditions\u003c/a\u003e  \u003c/span\u003e"},"disclaimer":"This coverage adds to the standard manufacturer’s limited warranty. Not available in Florida.","overlayTitle":"LG Premium Care by Asurion"},"deluxetvinstallation":{"title":"TV stand setup","description":"TV stand setup includes unboxing, package removal, installation of provided TV stand, place on flat surface, TV plug in, connect to one video source. TV Stand Setup does not include uninstallation of existing TV \u0026 haul away","buttonLabel":"What's included?","overlayTitle":"TV stand setup","itemTitle":"TV Stand Setup"},"haInstallation":{"title":"Add Professional Installation","icon":"HomeRepairServiceOutlined","subTitle":"Installation service includes installation and standard parts.","description":"We offer In-Home Delivery with Installation and Haul-Away for Major Appliances for an additional fee. Installation includes standard parts and services (i.e., connecting the appliance to existing standard fixtures and electrical outlets). Installation does not include hardwiring, side venting, water line extension, propane conversion, or any other special installation services. LG will not install new products onto existing products in the home, uninstallation of built in units, will not work with or touch exposed wires, rusted or corroded shut-off valves and copper valves, and will not remove entry way door. \u003c/br\u003e \u003c/br\u003e  Be sure to discuss all the necessary parts and specifications associated with your installation with the installation service provider when they contact you to schedule the installation. There may be some additional work or parts required that are not included in this service..","buttonLabel":"Installation requirements","overlayTitle":"Installation requirements","itemTitle":"Install Appliance","noService":{"itemTitle":"None"}},"haulawayAndMove":{"title":"Add Haul Away or Move","icon":"SyncAltOutlined","subTitle":"Without installation service, the installer will not haul away or move the old appliance(s) unless they have been uninstalled by the customer.","description":"Our delivery agents will only haul away or move appliances that are the same type as the one purchased. If installation service was not included in the order, it is the customer's responsibility to uninstall the appliance(s) that need to be hauled away or moved. Once haul away service has been completed, the old unit cannot be returned.","buttonLabel":"Learn more","overlayTitle":"Haul Away or Move","haulaway":{"itemTitle":"Haul Away"},"move":{"itemTitle":"Move Rooms"}},"rinse":{"title":"Add Laundry \u0026 Dry Cleaning Service","icon":"LocalLaundryServiceOutlined","subTitle":"Enjoy expertly cleaned laundry and dry cleaning delivered right to your door.","buttonLabel":"Learn more","itemTitle":"${RINSE_VALUE} in Rinse Credits","overlayTitle":"What is rinse?","description":"\u003cstyle\u003ep, h6{ margin: 0; } h6{ font-size: 22px; font-weight: 400; } \u003c/style\u003e\u003cp\u003eRinse provides door-to-door laundry and dry cleaning delivery. Your clothes are expertly cleaned and returned ready to wear, either crisply folded or neatly placed on hangers. Schedule a pickup 7 days a week at \u003ca href=\"https://www.rinse.com\" target=\"_blank\"\u003erinse.com\u003c/a\u003e, in the Rinse mobile app, or by simply texting \"Y\" to 746-73 (\"RINSE\"). Track your Valet in real time, customize your delivery and cleaning preferences, and enjoy a seamless laundry and dry cleaning experience designed with convenience at its core.\u003c/p\u003e\u003cbr\u003e\u003cp\u003eRinse serves customers in major markets across the US - learn more at \u003ca href=\"https://www.rinse.com/faqs/our-services/what-areas-do-you-serve/\" target=\"_blank\"\u003erinse.com\u003c/a\u003e.\u003c/p\u003e\u003cbr\u003e\u003ch6\u003eHow to redeem your ${RINSE_VALUE} in free Rinse credits?\u003c/h6\u003e\u003cp\u003eAfter you complete checkout, you will receive a follow-up message from Rinse on how to redeem your free ${RINSE_VALUE} credit.\u003c/p\u003e"},"serviceValuePack":{"title":"Add Expert Care and Proactive Member Benefits","icon":"SimpleMembership","subTitle":"Subscribe to the MyLG Ownership Program with a pro or pro care purchase for maintenance care and exclusive savings.","description":"","buttonLabel":"Discover the benefits","overlayTitle":"MyLG Ownership Program Benefits","itemTitle":"","noService":{"itemTitle":""},"proPlusTitle":"MyLG Ownership Program (pro)","proCarePlusTitle":"MyLG Ownership Program (pro care)","proImgSrc":"https://media.us.lg.com/transform/cc37d9ab-94fb-4bb4-b53c-2fd169bfc0f0/condensed_pro","proCareImgSrc":"https://media.us.lg