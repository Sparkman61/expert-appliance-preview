  <style>
  #pdp_reviews h2 {
    font-weight: 500 !important;
  }

  #pdp_reviews button.bv-submission-button.bv-first-to-ask-question,
  #bv-ips-submit,
  #pdp_reviews .bv-ask-question {
    border: 1px solid transparent !important;
    border-radius: 32px !important;
    color: #fff !important;
    transition: color .3s, background-color .3s, border .3s !important;
    box-shadow: none !important;
    -webkit-box-shadow: none !important;
    padding-bottom: 12px !important;
    padding-top: 12px !important;
  }

  #pdp_reviews button.bv-submission-button.bv-first-to-ask-question:hover,
  #pdp_reviews button.bv-submission-button.bv-first-to-ask-question:focus,
  #bv-ips-submit:hover,
  #pdp_reviews .bv-ask-question:hover {
    border: 1px solid #000 !important;
    color: #000 !important;
    background-color: #fff !important;
  }

  #bv-mbox-lightbox-list {
    background-color: #fff !important;
  }

  #bv-mbox-lightbox-list .bv-submission-section button.bv-submit {
    box-shadow: none !important;
    padding-top: 12px !important;
    padding-bottom: 12px !important;
    border: 1px solid transparent !important;
    background-image: none !important;
    transition: color .3s, background-color .3s, border .3s !important;
  }

  #bv-mbox-lightbox-list .bv-submission-section button.bv-submit:hover {
    border: 1px solid #000 !important;
  }

  #bv-mbox-lightbox-list .bv-mbox-content-container h2 {
    font-weight: 500 !important;
  }

  .ca-promotional-widget-link {
    color: #000 !important;
  }
</style>
<script>
  function $$(s, el = document.body) {
    const cs = Array.from(el.querySelectorAll('*')).map(el => el.shadowRoot).filter(Boolean);
    const cr = cs.map(c => $$(s, c));
    const r = Array.from(el.querySelectorAll(s));
    return r.concat(cr).flat();
  }
  const targetNode = document.body;
  const reviewsTarget = document.querySelector('[data-bv-show="reviews"]');
  const qTarget = document.querySelector('[data-bv-show="questions"]');
  const config = {
    attributes: true,
    childList: true,
    subtree: true
  };
  const callback = (mutationList, observer) => {
    for (let i = 0; i < $$('[data-bv-show="inpage_submission"]').length; i++) {
      if (i != $$('[data-bv-show="inpage_submission"]').length - 1) {
        $$('[data-bv-show="inpage_submission"]')[i].remove();
      }
    }
    for (const mutation of mutationList) {
      if (mutation.type === "childList" && mutation.addedNodes.length > 0) {
        for (const n of mutation.addedNodes) {
          if (n.attributes && n.getAttribute('data-bv-show') === 'inpage_submission') {
            const submitShadow = $$('[data-bv-show="inpage_submission"]')[$$('[data-bv-show="inpage_submission"]').length - 1];
            const bvHeadlineStyle = document.createElement('style');
            bvHeadlineStyle.innerHTML = 'h2{font-weight:500 !important;}';
            if (document.querySelector('[data-bv-show="reviews"]')) {
              document.querySelector('[data-bv-show="reviews"]').shadowRoot.appendChild(bvHeadlineStyle);
            }
            bvSubmitObserver.observe(submitShadow, config);
          }
        }
      }
    }
  };
  const bvSubmit = (mutationList, observer) => {
    for (const mutation of mutationList) {
      if (mutation.type === "attributes") {
        const bvSubmitCTAStyle = document.createElement('style');
        bvSubmitCTAStyle.innerHTML = 'button#bv-ips-submit, button#bv-ips-undefined {border: 1px solid transparent !important; padding: 0 1rem !important; transition: color .3s, background-color .3s, border .3s;} button#bv-ips-submit:hover, button#bv-ips-undefined:hover{border: 1px solid #000 !important;background-color: #fff !important;filter: none !important;padding-bottom: 12px !important;padding-top: 12px !important;} button#bv-ips-skip,button#bv-ips-cancel{color: #000 !important; border: 1px solid #000 !important; padding: 0 1rem !important; transition: color .3s, background-color .3s, border .3s;} button#bv-ips-skip:hover,button#bv-ips-cancel:hover{color: #fff !important; border: 1px solid rgb(234, 25, 23) !important;} div[type="main"] > div[role="dialog"] > div{background-color: #fff;}';
        $$('[data-bv-show="inpage_submission"]')[$$('[data-bv-show="inpage_submission"]').length - 1].shadowRoot.appendChild(bvSubmitCTAStyle);
        bvSubmitObserver.disconnect();
      }
    }
  };
  const reviewsCallback = (mutationList, observer) => {
    for (const mutation of mutationList) {
      if (mutation.type === "attributes") {
        const bvHeadlineStyle = document.createElement('style');
        bvHeadlineStyle.innerHTML = 'h2,h3{font-weight:500 !important;} [id*="bv-addComment"]{text-decoration: underline !important;}';
        if ($$('[data-bv-show="inpage_submission"]')[$$('[data-bv-show="inpage_submission"]').length - 1]) {
          $$('[data-bv-show="inpage_submission"]')[$$('[data-bv-show="inpage_submission"]').length - 1].shadowRoot.appendChild(bvHeadlineStyle);
        }
        const rsh = reviewsTarget.shadowRoot;
        const reviewsShadowObserver = new MutationObserver((mutationList, observer) => {
          for (const mutation of mutationList) {
            if (mutation.type === "childList" && mutation.addedNodes.length > 0 && mutation.addedNodes[0].id === 'bv-rnr-portal') {
              mutation.addedNodes[0].querySelector('bv-commentsubmission').removeAttribute('noshadowdom');
              setTimeout(function() {
                const bvCommentCancelCTAStyle = document.createElement('style');
                const bvCommentSubmitCTAStyle = document.createElement('style');
                bvCommentCancelCTAStyle.innerHTML = 'button.bv-button-class{color: #000 !important; border: 1px solid #000 !important; transition: color .3s, background-color .3s, border .3s;padding-bottom: 12px !important;padding-top: 12px !important;} button.bv-button-class:hover {border: 1px solid #EA1917 !important;color:#fff !important;background-color:#EA1917 !important;padding-bottom: 12px !important;padding-top: 12px !important;}';
                bvCommentSubmitCTAStyle.innerHTML = 'button.bv-button-class{border: 1px solid transparent !important; transition: color .3s, background-color .3s, border .3s;padding-bottom: 12px !important;padding-top: 12px !important;} button.bv-button-class:hover {border: 1px solid #000 !important;padding-bottom: 12px !important;padding-top: 12px !important;}';
                $$('bv-button')[0].removeAttribute('style');
                $$('bv-button')[1].removeAttribute('style');
                $$('bv-button')[0].shadowRoot.appendChild(bvCommentCancelCTAStyle);
                $$('bv-button')[1].shadowRoot.appendChild(bvCommentSubmitCTAStyle);
              }, 750);
            }
          }

        });
        reviewsShadowObserver.observe(rsh, config);
      }
    }
  };
  const questionsCallback = (mutationList, observer) => {
    for (const mutation of mutationList) {
      if (mutation.type === "attributes") {
        const qCTAStyle = document.createElement('style');
        const bvCommentCancelCTAStyle = document.createElement('style');
        const bvCommentSubmitCTAStyle = document.createElement('style');
        qCTAStyle.innerHTML = `
              [data-styled="active"] + div{padding: 10px 0 !important;} h2,h3{font-weight:500 !important;}
              #bv-question-btn{border: 1px solid transparent !important; transition: color .3s, background-color .3s, border .3s;padding-bottom: 12px !important;padding-top: 12px !important;}
              #bv-question-btn:hover{border: 1px solid #000 !important;padding-bottom: 12px !important;padding-top: 12px !important;}
          `;
        bvCommentCancelCTAStyle.innerHTML = 'button.bv-button-class{color: #000 !important; border: 1px solid #000 !important; transition: color .3s, background-color .3s, border .3s;padding-bottom: 12px !important;padding-top: 12px !important;} button.bv-button-class:hover {border: 1px solid #EA1917 !important;color:#fff !important;background-color:#EA1917 !important;padding-bottom: 12px !important;padding-top: 12px !important;}';
        bvCommentSubmitCTAStyle.innerHTML = 'button.bv-button-class{border: 1px solid transparent !important; transition: color .3s, background-color .3s, border .3s;padding-bottom: 12px !important;padding-top: 12px !important;} button.bv-button-class:hover {border: 1px solid #000 !important;padding-bottom: 12px !important;padding-top: 12px !important;}';
        if (qTarget) {
          qTarget.appendChild(qCTAStyle);
        }
      }
    }
  };
  const observer = new MutationObserver(callback);
  const reviewsObserver = new MutationObserver(reviewsCallback);
  const questionsObserver = new MutationObserver(questionsCallback);
  const bvSubmitObserver = new MutationObserver(bvSubmit);
  observer.observe(targetNode, config);
  if (reviewsTarget) {
    reviewsObserver.observe(reviewsTarget, config);
  }
  if (qTarget) {
    questionsObserver.observe(qTarget, config);
  }
</script>
